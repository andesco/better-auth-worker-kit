{
  "name": "better-auth-worker-kit",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "bun build src/web/client.ts --outdir public/assets --target browser --minify",
    "dev": "bun run build:client && wrangler dev",
    "deploy": "bun run build:client && wrangler deploy",
    "admin": "bun src/admin.ts",
    "check": "bun run build:client && wrangler types --check && tsc --noEmit && wrangler deploy --dry-run",
    "test": "bun test"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "latest",
    "@better-auth/passkey": "latest",
    "better-auth": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/bun": "latest",
    "typescript": "latest",
    "wrangler": "^4.111.0"
  }
}
